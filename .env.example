# Copy this file to ".env" and fill in the values from your Supabase project
# (Project Settings -> API). The anon key is public/safe for the browser.
# NEVER put the service_role key or the database password in this file.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
